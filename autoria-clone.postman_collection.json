                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/auth/logout-all"
          }
        }
      ]
    },
    {
      "name": "Account",
      "item": [
        {
          "name": "Buy Premium",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const userId = pm.collectionVariables.get(\"targetUserId\") || pm.variables.get(\"targetUserId\") || \"\";",
                  "const paymentReference = pm.collectionVariables.get(\"paymentReference\") || \"order-123\";",
                  "const paymentStatus = \"success\";",
                  "const secret = pm.collectionVariables.get(\"premiumPaymentSecret\") || \"\";",
                  "if (!userId || !secret) {",
                  "  console.log(\"Set targetUserId and premiumPaymentSecret before calling Buy Premium\");",
                  "} else {",
                  "  const payload = `${userId}:${paymentReference}:${paymentStatus}`;",
                  "  const signature = CryptoJS.HmacSHA256(payload, secret).toString(CryptoJS.enc.Hex);",
                  "  pm.collectionVariables.set(\"paymentSignature\", signature);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentStatus\": \"success\",\n  \"paymentReference\": \"{{paymentReference}}\",\n  \"paymentSignature\": \"{{paymentSignature}}\"\n}"
            },
            "url": "{{baseUrl}}/api/account/buy-premium"
          }
        }
      ]
    },
