            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Buyer User\",\n  \"age\": 24,\n  \"email\": \"buyer@example.com\",\n  \"password\": \"Qwerty123!\",\n  \"role\": \"buyer\",\n  \"accountType\": \"basic\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/sign-up"
          }
        },
        {
          "name": "Sign In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
