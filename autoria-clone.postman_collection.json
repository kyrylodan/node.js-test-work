            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Seller User\",\n  \"age\": 25,\n  \"email\": \"seller@example.com\",\n  \"password\": \"Qwerty123!\",\n  \"role\": \"seller\",\n  \"accountType\": \"basic\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/sign-up"
          }
        },
        {
          "name": "Sign Up Buyer",
          "request": {
            "method": "POST",
